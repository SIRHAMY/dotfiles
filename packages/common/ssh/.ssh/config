# SSH client config — managed by dotfiles.
#
# Global defaults below apply to all hosts. Add host-specific blocks above the
# `Host *` block (matches are first-wins; later directives merge).

Host *
    # Send an encrypted keepalive every 60s. Keeps NAT/firewall entries warm
    # so idle connections don't get silently evicted, and detects dead links
    # within ServerAliveInterval × ServerAliveCountMax (= 3 minutes).
    ServerAliveInterval 60
    ServerAliveCountMax 3
